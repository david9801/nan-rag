# Copia este fichero a .env y rellena los valores

# Clave de acceso al endpoint NaN Builders (obligatoria)
NAN_API_KEY=your_nan_api_key_here

# Endpoint de la API (por defecto apunta a NaN Builders)
NAN_BASE_URL=https://api.nan.builders/v1

# Modelos (los valores por defecto ya son los correctos para NaN)
EMBED_MODEL=qwen3-embedding
LLM_MODEL=deepseek-v4-flash

# Clave para proteger la API HTTP.
# Si se deja vacía, la autenticación queda desactivada (útil para desarrollo local).
# En producción (NaN Cloud), establece un valor secreto y pásalo como variable de entorno.
API_KEY=

# Ruta de ChromaDB.
# En Docker se sobreescribe automáticamente con /app/data/chroma_db via Dockerfile ENV.
# En local no es necesario cambiarlo.
# DB_PATH=./data/chroma_db
